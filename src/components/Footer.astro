---
const year = new Date().getFullYear();
---

<footer class="bg-swamp-900 text-swamp-200 mt-auto">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg bg-swamp-600 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2 C9 5 7 7 8 10 C6 9 4 11 6 13 C4 13 3 15 5 16
                       C4 17 4 19 6 19 L18 19 C20 19 20 17 19 16
                       C21 15 20 13 18 13 C20 11 18 9 16 10
                       C17 7 15 5 12 2Z"
                    fill="white" opacity="0.8"/>
            </svg>
          </div>
          <span class="font-bold text-white">CoolSwamps</span>
        </div>
        <p class="text-sm text-swamp-400 leading-relaxed max-w-xs">
          A community-driven scientific database of swamps, bogs, fens, and wetlands.
          All data is open and freely available.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3 uppercase tracking-wider">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-swamp-400 hover:text-white transition-colors">Map</a></li>
          <li><a href="/?view=table" class="text-swamp-400 hover:text-white transition-colors">Database</a></li>
          <li><a href="/submit" class="text-swamp-400 hover:text-white transition-colors">Submit a Swamp</a></li>
          <li><a href="/about" class="text-swamp-400 hover:text-white transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Data Sources -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3 uppercase tracking-wider">Data Sources</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://www.usgs.gov" target="_blank" rel="noopener noreferrer"
               class="text-swamp-400 hover:text-white transition-colors">
              USGS National Map ↗
            </a>
          </li>
          <li>
            <a href="https://www.gbif.org" target="_blank" rel="noopener noreferrer"
               class="text-swamp-400 hover:text-white transition-colors">
              GBIF Species Data ↗
            </a>
          </li>
          <li>
            <a href="https://www.inaturalist.org" target="_blank" rel="noopener noreferrer"
               class="text-swamp-400 hover:text-white transition-colors">
              iNaturalist ↗
            </a>
          </li>
          <li>
            <a href="https://websoilsurvey.nrcs.usda.gov" target="_blank" rel="noopener noreferrer"
               class="text-swamp-400 hover:text-white transition-colors">
              USDA Web Soil Survey ↗
            </a>
          </li>
          <li>
            <a href="https://www.fws.gov/program/national-wetlands-inventory" target="_blank" rel="noopener noreferrer"
               class="text-swamp-400 hover:text-white transition-colors">
              USFWS Wetlands Inventory ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-swamp-800 pt-6 flex flex-col sm:flex-row items-center
                justify-between gap-3 text-xs text-swamp-500">
      <p>&copy; {year} CoolSwamps. Data is community-contributed and open.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-swamp-300 transition-colors">Privacy</a>
        <a href="https://github.com/coolswamps/coolswamps" target="_blank" rel="noopener noreferrer"
           class="hover:text-swamp-300 transition-colors flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385
                     .6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235
                     -3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695
                     -.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23
                     1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605
                     -2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225
                     -.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405
                     3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24
                     2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625
                     -5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015
                     3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
