---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const swamps = await getCollection('swamps');
  return swamps.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const swamp = entry.data;

// ─── Rating rows ──────────────────────────────────────────────────────────────
const ratingRows = [
  {
    key:   'novelty'       as const,
    label: 'Novelty / Uniqueness',
    desc:  'How rare or distinctive is this wetland?',
  },
  {
    key:   'accessibility' as const,
    label: 'Social Setting Quality',
    desc:  'How easy is it for most people to access and enjoy?',
  },
  {
    key:   'habitat'       as const,
    label: 'Habitat Quality',
    desc:  'How healthy and diverse is the ecosystem?',
  },
].filter(r => swamp.ratings?.[r.key] !== undefined);

const terrainLabels = swamp.tags?.terrain?.map((t: string) => t.replace(/-/g, ' ')) ?? [];
const activityLabels = swamp.tags?.activities?.map((a: string) => a.replace(/-/g, ' ')) ?? [];
const soilLabels = swamp.tags?.soil?.map((s: string) => s.replace(/-/g, ' ')) ?? [];
const waterLabels = swamp.tags?.water_type?.map((w: string) => w.replace(/-/g, ' ')) ?? [];
const topoLabels = swamp.tags?.topography?.map((t: string) => t.replace(/-/g, ' ')) ?? [];
const vegLabels = swamp.tags?.vegetation ?? [];
const customLabels = swamp.tags?.custom ?? [];

const hasCoords = swamp.coordinates?.lat && swamp.coordinates?.lng;
const googleMapsUrl = hasCoords
  ? `https://www.google.com/maps?q=${swamp.coordinates.lat},${swamp.coordinates.lng}`
  : null;

// JSON-LD structured data for this swamp
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Place",
  "name": swamp.name,
  "description": swamp.description ?? '',
  "geo": hasCoords ? {
    "@type": "GeoCoordinates",
    "latitude": swamp.coordinates.lat,
    "longitude": swamp.coordinates.lng,
  } : undefined,
  "address": {
    "@type": "PostalAddress",
    "addressRegion": swamp.state,
    "addressLocality": swamp.county,
    "addressCountry": swamp.country ?? 'US',
  }
});
---

<BaseLayout
  title={swamp.name}
  description={swamp.description?.slice(0, 160) ?? `${swamp.name} — a wetland in ${swamp.county}, ${swamp.state}.`}
>
  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={jsonLd}></script>

  <div class="max-w-screen-lg mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-swamp-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-swamp-700 transition-colors">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/?view=table" class="hover:text-swamp-700 transition-colors">Database</a>
      <span aria-hidden="true">›</span>
      <span class="text-swamp-800 font-medium" aria-current="page">{swamp.name}</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-wrap items-start gap-3 mb-3">
        {swamp.status === 'visited'
          ? <span class="badge-visited text-sm px-3 py-1">✓ Visited</span>
          : <span class="badge-wishlist text-sm px-3 py-1">★ Want to Visit</span>
        }
        {swamp.verified && (
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold
                        bg-blue-50 text-blue-700 border border-blue-200">
            ✓ Verified
          </span>
        )}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-swamp-900 mb-2 text-balance">
        {swamp.name}
      </h1>
      <p class="text-lg text-swamp-600">
        {swamp.county} County, {swamp.state}
        {swamp.area_acres && (
          <span class="text-swamp-400 mx-2">·</span>
          <span>{swamp.area_acres.toLocaleString()} acres</span>
        )}
        {swamp.elevation_ft !== undefined && (
          <span class="text-swamp-400 mx-2">·</span>
          <span>{swamp.elevation_ft} ft elevation</span>
        )}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Main content -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Photos (placeholder) -->
        {swamp.photos.length === 0 && (
          <div class="card">
            <div class="card-body">
              <div class="aspect-video bg-swamp-50 rounded-lg flex items-center justify-center border-2 border-dashed border-swamp-200">
                <div class="text-center">
                  <svg class="mx-auto mb-2 text-swamp-300" width="36" height="36" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <path d="M21 15l-5-5L5 21"/>
                  </svg>
                  <p class="text-sm text-swamp-400">No photos yet</p>
                  <a href="/submit" class="text-xs text-swamp-600 hover:underline mt-1 inline-block">
                    Submit photos →
                  </a>
                </div>
              </div>
            </div>
          </div>
        )}

        <!-- Photos grid (when photos exist) -->
        {swamp.photos.length > 0 && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Photos</h2>
            </div>
            <div class="card-body">
              <div class="grid grid-cols-2 gap-3">
                {swamp.photos.map((photo: any, i: number) => (
                  <figure
                    class="relative rounded-lg overflow-hidden aspect-video bg-swamp-100 cursor-pointer group"
                    data-lightbox-src={`/photos/${photo.filename}`}
                    data-lightbox-caption={photo.caption ?? swamp.name}
                    data-lightbox-index={i}
                    role="button"
                    tabindex="0"
                    aria-label={`View full size: ${photo.caption ?? swamp.name}`}
                  >
                    <img
                      src={`/photos/${photo.filename}`}
                      alt={photo.caption ?? swamp.name}
                      class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                    <!-- Expand hint shown on hover -->
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/25 transition-colors
                                flex items-center justify-center pointer-events-none">
                      <svg class="text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-lg"
                           width="30" height="30" viewBox="0 0 24 24" fill="none"
                           stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                      </svg>
                    </div>
                    {photo.caption && (
                      <figcaption class="absolute bottom-0 left-0 right-0 bg-black/60 text-white text-xs px-2 py-1">
                        {photo.caption}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            </div>
          </div>
        )}

        <!-- Description -->
        {swamp.description && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Description</h2>
            </div>
            <div class="card-body">
              <p class="text-gray-700 leading-relaxed">{swamp.description}</p>
            </div>
          </div>
        )}

        <!-- Wildlife & Ecology -->
        {swamp.wildlife_notes && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Wildlife & Ecology</h2>
            </div>
            <div class="card-body">
              <p class="text-gray-700 leading-relaxed">{swamp.wildlife_notes}</p>
            </div>
          </div>
        )}

        <!-- History -->
        {swamp.historical_notes && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Historical Notes</h2>
            </div>
            <div class="card-body">
              <p class="text-gray-700 leading-relaxed">{swamp.historical_notes}</p>
            </div>
          </div>
        )}

        <!-- Access Notes -->
        {swamp.access_notes && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Access & Directions</h2>
            </div>
            <div class="card-body">
              <p class="text-gray-700 leading-relaxed">{swamp.access_notes}</p>
              {googleMapsUrl && (
                <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer"
                   class="mt-4 btn-secondary inline-flex text-sm">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  View on Google Maps ↗
                </a>
              )}
            </div>
          </div>
        )}

        <!-- Mini map for this swamp -->
        {hasCoords && (
          <div class="card">
            <div class="card-header flex items-center justify-between gap-3">
              <h2 class="text-base font-semibold text-swamp-900">Location</h2>

              <!-- Open in… dropdown -->
              <div class="relative shrink-0" id="map-open-wrap">
                <button id="map-open-btn" type="button"
                        class="inline-flex items-center gap-1 text-xs font-medium text-swamp-600
                               hover:text-swamp-900 border border-swamp-200 rounded-md px-2.5 py-1
                               hover:bg-swamp-50 transition-colors"
                        aria-haspopup="true" aria-expanded="false">
                  Open in
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </button>
                <div id="map-open-menu"
                     class="hidden absolute right-0 top-full mt-1 w-48 bg-white border border-swamp-200
                            rounded-lg shadow-lg z-20 py-1 text-sm"
                     role="menu">
                  <a href={`https://www.google.com/maps?q=${swamp.coordinates.lat},${swamp.coordinates.lng}`}
                     target="_blank" rel="noopener noreferrer"
                     class="flex items-center gap-2 px-3 py-2 text-swamp-700 hover:bg-swamp-50 transition-colors"
                     role="menuitem">
                    Google Maps ↗
                  </a>
                  <a href={`https://www.openstreetmap.org/?mlat=${swamp.coordinates.lat}&mlon=${swamp.coordinates.lng}&zoom=14`}
                     target="_blank" rel="noopener noreferrer"
                     class="flex items-center gap-2 px-3 py-2 text-swamp-700 hover:bg-swamp-50 transition-colors"
                     role="menuitem">
                    OpenStreetMap ↗
                  </a>
                  <a href={`https://caltopo.com/map.html#ll=${swamp.coordinates.lat},${swamp.coordinates.lng}&z=14&b=mbt&a=sf`}
                     target="_blank" rel="noopener noreferrer"
                     class="flex items-center gap-2 px-3 py-2 text-swamp-700 hover:bg-swamp-50 transition-colors"
                     role="menuitem">
                    CalTopo ↗
                  </a>
                  <a href={`https://www.inaturalist.org/observations?lat=${swamp.coordinates.lat}&lng=${swamp.coordinates.lng}&radius=5&view=map`}
                     target="_blank" rel="noopener noreferrer"
                     class="flex items-center gap-2 px-3 py-2 text-swamp-700 hover:bg-swamp-50 transition-colors"
                     role="menuitem">
                    iNaturalist nearby ↗
                  </a>
                </div>
              </div>
            </div>

            <!-- Map container — coordinates passed via data attributes (define:vars
                 cannot be combined with ES module imports in Astro) -->
            <div class="card-body p-0 overflow-hidden rounded-b-xl">
              <div id="swamp-mini-map"
                   data-lat={swamp.coordinates.lat}
                   data-lng={swamp.coordinates.lng}
                   data-name={swamp.name}
                   data-status={swamp.status}
                   style="height:280px;width:100%"></div>
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">

        <!-- Ratings -->
        {ratingRows.length > 0 && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Ratings</h2>
            </div>
            <div class="card-body divide-y divide-swamp-50">
              {ratingRows.map(r => {
                const score = swamp.ratings![r.key]!;
                return (
                  <div class="py-3 first:pt-0 last:pb-0">
                    <div class="flex items-baseline justify-between mb-0.5">
                      <span class="text-sm font-medium text-swamp-800">{r.label}</span>
                      <span class="text-xs font-semibold text-swamp-400">{score} / 5</span>
                    </div>
                    <p class="text-xs text-swamp-500 mb-1.5">{r.desc}</p>
                    <div class="flex gap-0.5" role="img" aria-label={`${score} out of 5 stars`}>
                      {[1,2,3,4,5].map(i => (
                        <svg width="18" height="18" viewBox="0 0 24 24"
                             fill={i <= score ? '#f59e0b' : 'none'}
                             stroke={i <= score ? '#d97706' : '#d1d5db'}
                             stroke-width="1.5" aria-hidden="true">
                          <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
                        </svg>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Quick facts -->
        <div class="card">
          <div class="card-header">
            <h2 class="text-base font-semibold text-swamp-900">Quick Facts</h2>
          </div>
          <div class="card-body space-y-3 text-sm">
            <div class="flex justify-between gap-2">
              <span class="text-swamp-500 font-medium">State</span>
              <span class="text-swamp-900 text-right">{swamp.state}</span>
            </div>
            <div class="flex justify-between gap-2">
              <span class="text-swamp-500 font-medium">County</span>
              <span class="text-swamp-900 text-right">{swamp.county}</span>
            </div>
            {swamp.area_acres && (
              <div class="flex justify-between gap-2">
                <span class="text-swamp-500 font-medium">Area</span>
                <span class="text-swamp-900">{swamp.area_acres.toLocaleString()} ac</span>
              </div>
            )}
            {swamp.elevation_ft !== undefined && (
              <div class="flex justify-between gap-2">
                <span class="text-swamp-500 font-medium">Elevation</span>
                <span class="text-swamp-900">{swamp.elevation_ft} ft</span>
              </div>
            )}
            {swamp.difficulty && (
              <div class="flex justify-between gap-2">
                <span class="text-swamp-500 font-medium">Difficulty</span>
                <span class="text-swamp-900 capitalize">{swamp.difficulty}</span>
              </div>
            )}
            {swamp.best_season?.length > 0 && (
              <div class="flex justify-between gap-2">
                <span class="text-swamp-500 font-medium">Best Season</span>
                <span class="text-swamp-900 text-right capitalize">
                  {swamp.best_season.join(', ')}
                </span>
              </div>
            )}
            {hasCoords && (
              <div class="flex justify-between gap-2">
                <span class="text-swamp-500 font-medium">Coordinates</span>
                <span class="text-swamp-900 font-mono text-xs text-right">
                  {swamp.coordinates.lat.toFixed(4)}, {swamp.coordinates.lng.toFixed(4)}
                </span>
              </div>
            )}
          </div>
        </div>

        <!-- Terrain & Habitat -->
        {(terrainLabels.length > 0 || soilLabels.length > 0 || waterLabels.length > 0 || topoLabels.length > 0) && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Terrain & Habitat</h2>
            </div>
            <div class="card-body space-y-4 text-sm">
              {terrainLabels.length > 0 && (
                <div>
                  <p class="text-swamp-500 font-medium text-xs uppercase tracking-wider mb-1.5">Terrain Type</p>
                  <div class="flex flex-wrap gap-1">
                    {terrainLabels.map((t: string) => <span class="badge-tag capitalize">{t}</span>)}
                  </div>
                </div>
              )}
              {soilLabels.length > 0 && (
                <div>
                  <p class="text-swamp-500 font-medium text-xs uppercase tracking-wider mb-1.5">Soil</p>
                  <div class="flex flex-wrap gap-1">
                    {soilLabels.map((s: string) => <span class="badge-tag capitalize">{s}</span>)}
                  </div>
                </div>
              )}
              {waterLabels.length > 0 && (
                <div>
                  <p class="text-swamp-500 font-medium text-xs uppercase tracking-wider mb-1.5">Water Type</p>
                  <div class="flex flex-wrap gap-1">
                    {waterLabels.map((w: string) => <span class="badge-tag capitalize">{w}</span>)}
                  </div>
                </div>
              )}
              {topoLabels.length > 0 && (
                <div>
                  <p class="text-swamp-500 font-medium text-xs uppercase tracking-wider mb-1.5">Topography</p>
                  <div class="flex flex-wrap gap-1">
                    {topoLabels.map((t: string) => <span class="badge-tag capitalize">{t}</span>)}
                  </div>
                </div>
              )}
            </div>
          </div>
        )}

        <!-- Activities -->
        {activityLabels.length > 0 && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Activities</h2>
            </div>
            <div class="card-body">
              <div class="flex flex-wrap gap-1.5">
                {activityLabels.map((a: string) => <span class="badge-tag capitalize">{a}</span>)}
              </div>
            </div>
          </div>
        )}

        <!-- Vegetation -->
        {vegLabels.length > 0 && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Vegetation</h2>
            </div>
            <div class="card-body">
              <div class="flex flex-wrap gap-1.5">
                {vegLabels.map((v: string) => <span class="badge-tag italic">{v.replace(/-/g, ' ')}</span>)}
              </div>
            </div>
          </div>
        )}

        <!-- Custom tags -->
        {customLabels.length > 0 && (
          <div class="card">
            <div class="card-header">
              <h2 class="text-base font-semibold text-swamp-900">Notable Features</h2>
            </div>
            <div class="card-body">
              <div class="flex flex-wrap gap-1.5">
                {customLabels.map((c: string) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                                bg-blue-50 text-blue-700 border border-blue-200">
                    {c.replace(/-/g, ' ')}
                  </span>
                ))}
              </div>
            </div>
          </div>
        )}

        <!-- Submitted / updated dates -->
        <div class="text-xs text-swamp-400 space-y-1 px-1">
          <p>Submitted: {swamp.submitted_date}</p>
          <p>Last updated: {swamp.last_updated}</p>
        </div>

        <!-- Suggest an edit CTA -->
        <a href={`/swamps/${entry.id}/edit`}
           class="btn-secondary w-full justify-center text-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          Suggest an Edit
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<!-- ── Lightbox overlay ───────────────────────────────────────────────────── -->
{swamp.photos.length > 0 && (
  <div id="lightbox"
       class="fixed inset-0 z-50 hidden items-center justify-center bg-black/92"
       role="dialog" aria-modal="true" aria-label="Photo viewer">

    <!-- Close -->
    <button id="lightbox-close"
            class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors z-10 p-1"
            aria-label="Close photo viewer">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Previous -->
    <button id="lightbox-prev"
            class="absolute left-3 sm:left-5 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-10 p-2 hidden"
            aria-label="Previous photo">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <!-- Image + caption -->
    <div class="flex flex-col items-center gap-3 px-14">
      <img id="lightbox-img" src="" alt=""
           class="max-w-[90vw] max-h-[82vh] object-contain rounded shadow-2xl" />
      <div class="flex items-center gap-4 text-sm min-h-[1.5rem]">
        <span id="lightbox-caption" class="text-white/85"></span>
        <span id="lightbox-counter" class="text-white/45 font-mono text-xs"></span>
      </div>
    </div>

    <!-- Next -->
    <button id="lightbox-next"
            class="absolute right-3 sm:right-5 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-10 p-2 hidden"
            aria-label="Next photo">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>
)}

<script>
// ── Lightbox ───────────────────────────────────────────────────────────────────
const lightbox     = document.getElementById('lightbox');
const lbImg        = document.getElementById('lightbox-img') as HTMLImageElement | null;
const lbCaption    = document.getElementById('lightbox-caption');
const lbCounter    = document.getElementById('lightbox-counter');
const lbClose      = document.getElementById('lightbox-close');
const lbPrev       = document.getElementById('lightbox-prev');
const lbNext       = document.getElementById('lightbox-next');

if (lightbox && lbImg) {
  const figures = Array.from(
    document.querySelectorAll<HTMLElement>('[data-lightbox-src]')
  );
  let current = 0;

  function openAt(index: number) {
    current = (index + figures.length) % figures.length;
    const fig = figures[current];
    lbImg!.src = fig.dataset.lightboxSrc!;
    lbImg!.alt = fig.dataset.lightboxCaption ?? '';
    if (lbCaption) lbCaption.textContent = fig.dataset.lightboxCaption ?? '';
    if (lbCounter) lbCounter.textContent = figures.length > 1 ? `${current + 1} / ${figures.length}` : '';
    if (figures.length > 1) {
      lbPrev?.classList.remove('hidden');
      lbNext?.classList.remove('hidden');
    }
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
    lbClose?.focus();
  }

  function close() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    lbImg!.src = '';
  }

  // Open on click / Enter / Space
  figures.forEach((fig, i) => {
    fig.addEventListener('click', () => openAt(i));
    fig.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openAt(i); }
    });
  });

  lbClose?.addEventListener('click', close);
  lbPrev?.addEventListener('click',  () => openAt(current - 1));
  lbNext?.addEventListener('click',  () => openAt(current + 1));

  // Click on the dark backdrop (not the image) to close
  lightbox.addEventListener('click', (e: MouseEvent) => {
    if (e.target === lightbox) close();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  openAt(current - 1);
    if (e.key === 'ArrowRight') openAt(current + 1);
  });
}
</script>

<!-- Mini map + dropdown — regular module script reads coordinates from data-* attributes.
     Astro does not allow ES module imports inside define:vars scripts, so we pass
     server-side values through the DOM instead. -->
<script>
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';

// ── Mini map ──────────────────────────────────────────────────────────────────
const mapEl = document.getElementById('swamp-mini-map') as HTMLElement | null;
if (mapEl) {
  const lat    = parseFloat(mapEl.dataset.lat    ?? '0');
  const lng    = parseFloat(mapEl.dataset.lng    ?? '0');
  const name   = mapEl.dataset.name   ?? '';
  const status = mapEl.dataset.status ?? '';

  const miniMap = L.map('swamp-mini-map', { zoomControl: true, scrollWheelZoom: false })
    .setView([lat, lng], 11);

  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
  }).addTo(miniMap);

  const color = status === 'visited' ? '#0d9488' : '#ea580c';
  const icon = L.divIcon({
    className: '',
    html: `<div style="width:22px;height:22px;background:${color};border:2px solid rgba(0,0,0,0.4);
                       border-radius:50% 50% 50% 0;transform:rotate(-45deg);
                       box-shadow:2px 2px 4px rgba(0,0,0,0.3)"></div>`,
    iconSize: [22, 22], iconAnchor: [11, 22],
  });
  L.marker([lat, lng], { icon, title: name }).addTo(miniMap);
}

// ── "Open in" dropdown ────────────────────────────────────────────────────────
const openBtn  = document.getElementById('map-open-btn');
const openMenu = document.getElementById('map-open-menu');
if (openBtn && openMenu) {
  openBtn.addEventListener('click', (e: MouseEvent) => {
    e.stopPropagation();
    const isOpen = !openMenu.classList.contains('hidden');
    openMenu.classList.toggle('hidden');
    openBtn.setAttribute('aria-expanded', String(!isOpen));
  });
  // Close when clicking anywhere outside
  document.addEventListener('click', () => {
    openMenu.classList.add('hidden');
    openBtn.setAttribute('aria-expanded', 'false');
  });
}
</script>
